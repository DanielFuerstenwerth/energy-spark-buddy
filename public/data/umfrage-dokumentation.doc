  <!-- ===== LOGISCHE VERBINDUNGEN ===== -->
  <div style="page-break-before: always; margin-top: 24pt;">
    <h2 style="color: #1a365d; border-bottom: 2pt solid #22c55e; padding-bottom: 6pt;">📊 Zusammenfassung: Logische Verbindungen</h2>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">1. Multi-Evaluation Architektur</h3>
    <table class="tbl">
      <tr style="background: #e5e7eb;"><th>Typ</th><th>Abschnitte</th><th>Beschreibung</th></tr>
      <tr><td>🌐 Global</td><td>A, E, Abschluss</td><td>Einmal pro Sitzung, gilt für alle Tabs</td></tr>
      <tr><td>📋 Pro Evaluation</td><td>Projektdetails, B, B6, C, C8, D, Dienstleister, M, MP, MB</td><td>Separat für jeden VNB/Tab</td></tr>
    </table>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">2. Projektart → Abschnitt-Sichtbarkeit</h3>
    <table class="tbl">
      <tr style="background: #e5e7eb;"><th>projectTypes</th><th>Sichtbare Abschnitte</th></tr>
      <tr><td>ggv</td><td>B, B6, C, C8, D, Dienstleister (+ GGV-Dimensionen)</td></tr>
      <tr><td>mieterstrom</td><td>B, B6, M, MP, MB (+ Mieterstrom-Dimensionen)</td></tr>
      <tr><td>ggv_oder_mieterstrom</td><td>B, B6, C, C8, D, Dienstleister, M, MP, MB (alle)</td></tr>
      <tr><td>energysharing (allein)</td><td>Nur E (Energy Sharing)</td></tr>
    </table>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">3. Planungsstatus → Betrieb</h3>
    <table class="tbl">
      <tr style="background: #e5e7eb;"><th>planningStatus</th><th>Wirkung</th></tr>
      <tr><td>pv_laeuft_ggv_laeuft</td><td>→ D. GGV Betrieb + Dienstleister / MB. Mieterstrom Betrieb</td></tr>
      <tr><td>Alle anderen</td><td>→ Nur Planungs-Abschnitte (C/M/MP)</td></tr>
    </table>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">4. Standort-Logik (#16)</h3>
    <table class="tbl">
      <tr style="background: #e5e7eb;"><th>Projektumfang</th><th>UI-Verhalten</th></tr>
      <tr><td>single</td><td>1 Zeile: PLZ + Adresse</td></tr>
      <tr><td>multiple</td><td>Dynamische Zeilen (+/−): PLZ + Adresse + kW</td></tr>
    </table>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">5. Wichtige Sprunglogiken</h3>
    <table class="tbl">
      <tr style="background: #e5e7eb;"><th>Frage</th><th>Auswahl</th><th>Wirkung</th></tr>
      <tr><td>C8 vnbMsbOffer</td><td>ja</td><td>→ C8.1a–f</td></tr>
      <tr><td>C8 vnbMsbOffer</td><td>nein_wmsb</td><td>→ C8.2a</td></tr>
      <tr><td>C8 vnbMsbOffer</td><td>nein_gar_nicht</td><td>→ C8.2b</td></tr>
      <tr><td>vnbAdditionalCosts</td><td>ja</td><td>→ Kostenfelder (mind. 1 Pflicht)</td></tr>
      <tr><td>B2 ggvOrMieterstromDecision</td><td>sicher_ggv</td><td>→ B3 Gründe</td></tr>
      <tr><td>B2 ggvOrMieterstromDecision</td><td>sicher_mieterstrom</td><td>→ B4 Gründe</td></tr>
      <tr><td>M1 mieterstromSummenzaehler</td><td>virtuell</td><td>→ M6 + M7</td></tr>
      <tr><td>E6 esVnbContact</td><td>yes</td><td>→ E7 + E8</td></tr>
    </table>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">6. Exklusive Optionen</h3>
    <ul style="font-size: 10pt;">
      <li>B6 challenges: "keine" → alle anderen abwählen</li>
      <li>M2 mieterstromChallenges: "keine" → alle anderen abwählen</li>
    </ul>

    <h3 style="color: #1a365d; font-size: 13pt; margin-top: 16pt;">7. Bedingte Pflichtfelder</h3>
    <ul style="font-size: 10pt;">
      <li>#36/#37: vnbAdditionalCosts = 'ja' → mindestens Einmal- oder Jahresbetrag</li>
      <li>#57/#58: operationMsbAdditionalCosts = 'ja' → mindestens eins</li>
      <li>#87/#88: mieterstromMsbCosts = 'ja' → mindestens eins</li>
    </ul>
