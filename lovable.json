{
  "$schema": "https://lovable.dev/schemas/lovable.json",
  "static": {
    "paths": [
      "/umfrage/audit",
      "/umfrage/audit/",
      "/umfrage/audit/index.html",
      "/data/*",
      "/audit.html"
    ]
  },
  "rewrites": [
    {
      "source": "/umfrage/audit",
      "destination": "/umfrage/audit/index.html"
    },
    {
      "source": "/umfrage/audit/",
      "destination": "/umfrage/audit/index.html"
    },
    {
      "source": "/data/:path*",
      "destination": "/data/:path*"
    }
  ],
  "fallback": {
    "source": "/(.*)",
    "destination": "/index.html",
    "exclude": ["/umfrage/audit*", "/data/*", "/audit.html"]
  }
}
